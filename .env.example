# NanoClaw Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Claude authentication (pick ONE):
# Option A — Claude Pro/Max subscription:
#   Run `claude setup-token` in another terminal, paste the token here
CLAUDE_CODE_OAUTH_TOKEN=
# Option B — Anthropic API key:
#   Get from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ─── Optional ────────────────────────────────────────────────────────

# Assistant name (default: Andy). This is the trigger word in group chats.
# ASSISTANT_NAME=Andy

# Claude model to use (default: claude-sonnet-4-6)
# NANOCLAW_MODEL=claude-sonnet-4-6

# Agent timeout in milliseconds (default: 300000 = 5 minutes)
# CONTAINER_TIMEOUT=300000

# Max message history age in milliseconds (default: 14400000 = 4 hours)
# MAX_HISTORY_AGE_MS=14400000

# OpenAI API key for voice message transcription (optional)
# OPENAI_API_KEY=

# GitHub token for agent git operations (optional)
# GITHUB_TOKEN=

# Log level: fatal, error, warn, info, debug, trace (default: info)
# LOG_LEVEL=info
